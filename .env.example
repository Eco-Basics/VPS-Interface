# Copy to .env and fill in values before running
# NOTE: bcrypt is a native C++ module. If npm install fails with "gyp ERR!", run:
#   sudo apt-get install -y build-essential python3
# then re-run npm install. Alternatively, replace bcrypt with bcryptjs@2.4.3 (pure JS,
# identical API: import bcrypt from 'bcryptjs') — no native build required.

PASSWORD=your-login-password-here
JWT_SECRET=replace-with-64-char-random-hex-string
PORT=3000
CLAUDE_CMD=claude
